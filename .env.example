APP_NAME="Perpustakaan Daerah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------------------
# Database — Supabase PostgreSQL
# Dapatkan credentials dari: Supabase Dashboard > Project Settings > Database
# -------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db.<YOUR_SUPABASE_PROJECT_REF>.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=<YOUR_SUPABASE_DB_PASSWORD>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------------------
# Storage — Supabase S3-Compatible Storage
# Dapatkan credentials dari: Supabase Dashboard > Project Settings > API > S3 Access Keys
# 1. AWS_ACCESS_KEY_ID     = S3 Access Key ID
# 2. AWS_SECRET_ACCESS_KEY = S3 Secret Access Key
# 3. AWS_BUCKET            = Nama bucket yang dibuat di Supabase Storage (misal: "storage")
# 4. AWS_ENDPOINT           = https://<PROJECT_REF>.supabase.co/storage/v1/s3
# -------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<YOUR_S3_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_S3_SECRET_ACCESS_KEY>
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=storage
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=https://<YOUR_SUPABASE_PROJECT_REF>.supabase.co/storage/v1/s3

VITE_APP_NAME="${APP_NAME}"
